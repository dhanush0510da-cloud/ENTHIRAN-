let fleetDB = [
    { rid: 'R-1', name: 'John Doe', status: 'idle', tag: 'waiting', batch: 'None' },
    { rid: 'R-2', name: 'Sarah S.', status: 'idle', tag: 'waiting', batch: 'None' },
